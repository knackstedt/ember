{
  "name": "ember",
  "desktopName": "Ember",
  "version": "0.6.0",
  "description": "Home Theater PC Application",
  "license": "PolyForm-Noncommercial-1.0.0",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js && bun scripts/build-rust.ts && bun scripts/build-native.ts && bun scripts/setup-rclone.ts && cd native/libretro-frontend && cargo fetch",
    "predev": "bun scripts/build-rust.ts && bun scripts/build-native.ts",
    "dev": "bun scripts/dev.ts",
    "prebuild": "bun scripts/build-rust.ts && bun scripts/build-native.ts",
    "build": "electron-vite build",
    "predist": "bun scripts/build-rust.ts && bun scripts/build-native.ts",
    "dist": "electron-builder",
    "dist:x64:tar.gz": "electron-builder --linux tar.gz --x64",
    "dist:x64:appimage": "electron-builder --linux AppImage --x64",
    "preview": "electron-vite preview",
    "lint": "eslint src",
    "tsc": "tsc --noEmit --project tsconfig.web.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "retag": "VERSION=$(jq -r '.version' package.json) && git push origin :refs/tags/v${VERSION} 2>/dev/null || true && git tag -d v${VERSION} 2>/dev/null || true && git tag v${VERSION} && git push origin v${VERSION} --force"
  },
  "dependencies": {
    "@dotglitch/odatav4": "^5.0.1",
    "@fontsource/mukta-vaani": "^5.2.8",
    "@ruffle-rs/ruffle": "^0.3.0",
    "@surrealdb/node": "^3.0.0",
    "@xenova/transformers": "^2.17.2",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "castv2": "^0.1.10",
    "electron-updater": "^6.8.9",
    "esbuild": "^0.28.1",
    "framer-motion": "^12.42.2",
    "jsnes": "^2.1.0",
    "lucide-react": "^1.23.0",
    "matrix-animation": "^2.0.0",
    "multicast-dns": "^7.2.5",
    "music-metadata": "^11.13.0",
    "node-id3": "^0.2.6",
    "node-stream-zip": "^1.15.0",
    "react-grid-layout": "^2.2.3",
    "simple-icons": "^16.24.1",
    "source-map": "^0.7.4",
    "surrealdb": "^2.0.4",
    "virtua": "^0.49.2",
    "x11": "^2.3.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^2.1.0",
    "@types/source-map": "^0.5.7",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "electron": "^31.0.2",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "dev.dotglitch.ember",
    "productName": "Ember",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "AudioVideo;Game;Audio;Video;Emulator;",
      "maintainer": "dotglitch",
      "vendor": "dotglitch"
    },
    "flatpak": {
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "23.08",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp",
      "baseVersion": "23.08",
      "finishArgs": [
        "--socket=wayland",
        "--socket=x11",
        "--share=ipc",
        "--device=dri",
        "--socket=pulseaudio",
        "--filesystem=home"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "knackstedt",
      "repo": "ember",
      "releaseType": "release"
    }
  }
}
